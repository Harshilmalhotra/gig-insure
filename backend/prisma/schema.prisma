// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String        @id @default(uuid())
  phone             String        @unique // Added for phone-based auth
  password          String?       
  name              String
  platform          String        // Swiggy, Zomato
  baseEarnings      Float         @default(0)
  baseRating        Float         @default(0)
  avgDailyEarnings  Float         @default(0) // Field added for mock platform sync
  ordersPerHour     Float         @default(0) // Field added for mock platform sync
  rating            Float         @default(0) // Field added for mock platform sync
  consistencyScore  Float         @default(0)
  createdAt         DateTime      @default(now())
  policies          Policy[]
  workerStates      WorkerState[]
  claims            Claim[]
  forcedOrdersPerHour Float?
  forcedMotion        String?
  forcedGpsPattern    String?
}

model Policy {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id])
  userId            String
  coverage          Float
  premium           Float
  startDate         DateTime  @default(now())
  endDate           DateTime
  status            String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED
  claims            Claim[]
}

model WorkerState {
  id                String    @id @default(uuid())
  user              User      @relation(fields: [userId], references: [id])
  userId            String
  timestamp         DateTime  @default(now())
  ordersPerHour     Float
  motion            String    // "moving", "idle"
  gpsPattern        String    // "smooth", "anomaly"
  earnings          Float
  lat               Float?    // Added for real GPS
  lon               Float?    // Added for real GPS
  active            Boolean   @default(true)
}

model EnvironmentState {
  id                String    @id @default(uuid())
  timestamp         DateTime  @default(now())
  rain              Float
  temperature       Float
  aqi               Int
  demandLevel       String    // "low", "medium", "high"
  platformStatus    String    // "online", "outage"
  isSimulated       Boolean   @default(false)
}

model Claim {
  id                String    @id @default(uuid())
  policy            Policy    @relation(fields: [policyId], references: [id])
  policyId          String
  user              User      @relation(fields: [userId], references: [id])
  userId            String
  triggerType       String    // RAIN, HEAT, DEMAND_CRASH, OUTAGE, POLLUTION
  payoutAmount      Float
  fraudScore        Float
  activityScore     Float
  status            String    @default("PENDING") // FLAGGED, PENDING_REVIEW, PAID, REJECTED
  evidenceUrl       String?   // New: Video/Image proof
  adminNotes        String?   // New: Human review response
  createdAt         DateTime  @default(now())
}
